# Copy to .env.local and fill in real values (never commit .env.local)
# https://sendgrid.com — API Key 在 Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxx

# SendGrid 里已验证的发件地址（Single Sender Verification 或域名认证后的邮箱）
SENDGRID_FROM_EMAIL="Preplan <noreply@your-verified-domain.com>"

# 收到网站表单通知的邮箱
CONTACT_TO_EMAIL=you@example.com
