# Copy to .env.local and fill in real values (never commit .env.local)
# AWS SES — IAM user with ses:SendEmail on verified identities
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# Must match addresses verified in Amazon SES (same region as above)
SES_FROM_EMAIL=verified-sender@example.com
SES_TO_EMAIL=your-inbox@example.com
